package patterns;

public class Pattern12 {

	public static void main(String[] args) {
		
		int n =4;
		for (int i=1;i<=n; i++)
		{
			for (int j=1;j<=i;j++)
			{
				System.out.print(j);
			}
			
			// Create the space:
			for (int k=0;k<=2*(n-i); k++)
			{
				System.out.print(" ");
			}

			
			//Print Number.
			for (int j=i;j>0;j--)
			{
				System.out.print(j);
			}
		System.out.println();
		}
	}
}
