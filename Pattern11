package patterns;

public class Pattern11 {

	public static void main(String[] args) {
		int start =0;
		for ( int i =1;i <=5; i++)
		{
			
			start = (i % 2 == 0) ? 0 : 1;
			
			for (int j=0;j<i; j++)
			{
				System.out.print(start);
				if (start == 0)
					start = start + 1;
				else
					start = start -1;
			}
			System.out.println();
		}
		
	}
}
