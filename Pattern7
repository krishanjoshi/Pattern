package patterns;

public class Pattern7 {
    public static void main(String[] args) {
    	
    	int n=5;
    	for (int i =1;i <= n ;i++)
    	{
    		//draw the spaces.
    		for(int j=0;j<(n-i);j++)
    			System.out.print(" ");
    		
    		//Print *
    		for (int k=0;k<(2*i-1);k++)
    			System.out.print("*");
    	
    		System.out.println();
    	}
    	
    }
    
}
